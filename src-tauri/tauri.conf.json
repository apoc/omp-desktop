{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OMP Desktop",
  "version": "0.1.2",
  "identifier": "dev.ohMyPi.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost; frame-src 'none'; object-src 'none'",
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "OMP Desktop",
        "url": "index.html",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "shadow": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
